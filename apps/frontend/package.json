{
  "name": "pumped-frontend",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "bun run dev:prepare && expo run:android",
    "ios": "bun run dev:prepare && expo run:ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "start": "bun run dev:prepare && react-native start",
    "test": "jest --passWithNoTests",
    "e2e": "bun run scripts/ensure-metro.ts && maestro-runner --platform ios test -e APP_ID=org.reactjs.native.example.PumpedApp .maestro",
    "e2e:android": "bun run scripts/ensure-metro.ts && maestro-runner --platform android test -e APP_ID=com.pumpedapp .maestro",
    "postinstall": "node scripts/postinstall.js",
    "dev:prepare": "echo 'Frontend is ready!'",
    "db:generate": "drizzle-kit generate && bun run scripts/generate-migrations.ts",
    "ios:clean": "bun run dev:prepare && expo start --clear --ios",
    "setup:ios": "cd ios && pod deintegrate && pod install",
    "setup:android": "cd android && ./gradlew clean"
  },
  "dependencies": {
    "@expo/ui": "~56.0.16",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/material-top-tabs": "^7.4.28",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "babel-preset-expo": "~56.0.0",
    "drizzle-orm": "^0.45.2",
    "expo": "^56.0.0",
    "expo-crypto": "~56.0.4",
    "expo-image-picker": "^56.0.16",
    "expo-sqlite": "~56.0.4",
    "heroui-native": "^1.0.2",
    "i18next": "^26.3.1",
    "react": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-base64": "^0.2.2",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-pager-view": "8.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "uniwind": "^1.6.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@eslint/js": "^10.0.1",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-base64": "^0.2.2",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "resolutions": {
    "@react-native/babel-plugin-codegen": "0.85.3",
    "@react-native/codegen": "0.85.3"
  }
}

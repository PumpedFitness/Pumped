{
  "name": "pumped",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "frontend": "bun --cwd=apps/frontend run start",
    "frontend:ios": "bun --cwd=apps/frontend run ios",
    "frontend:android": "bun --cwd=apps/frontend run android",
    "frontend:lint": "bun --cwd=apps/frontend run lint",
    "frontend:lint:fix": "bun --cwd=apps/frontend run lint:fix",
    "frontend:format": "bun --cwd=apps/frontend run format",
    "frontend:format:check": "bun --cwd=apps/frontend run format:check",
    "frontend:test": "bun --cwd=apps/frontend run test",
    "frontend:e2e": "bun --cwd=apps/frontend run e2e",
    "frontend:e2e:android": "bun --cwd=apps/frontend run e2e:android",
    "frontend:typecheck": "bun --cwd=apps/frontend run typecheck",
    "frontend:db:generate": "bun --cwd=apps/frontend run db:generate",
    "frontend:prepare": "bun --cwd=apps/frontend run dev:prepare",
    "frontend:setup:ios": "bun --cwd=apps/frontend run setup:ios",
    "frontend:setup:android": "bun --cwd=apps/frontend run setup:android",
    "check:verify": "bun run frontend:format:check && bun run frontend:lint && bun run frontend:typecheck",
    "check:precommit": "bun run check:verify && bun run frontend:test",
    "check:finish": "bash scripts/agent-check.sh",
    "check:e2e:ios": "bun run frontend:e2e",
    "check:e2e:android": "bun run frontend:e2e:android",
    "install:all": "cd apps/frontend && bun install"
  }
}

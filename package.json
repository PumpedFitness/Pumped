{
  "name": "pumped",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "frontend": "bun run --cwd apps/frontend start",
    "frontend:ios": "bun run --cwd apps/frontend ios",
    "frontend:android": "bun run --cwd apps/frontend android",
    "frontend:lint": "bun run --cwd apps/frontend lint",
    "frontend:test": "bun run --cwd apps/frontend test",
    "backend": "echo 'Backend not yet configured. Add the existing repo to apps/backend.'",
    "backend:build": "echo 'Backend not yet configured.'",
    "install:all": "bun install"
  }
}
